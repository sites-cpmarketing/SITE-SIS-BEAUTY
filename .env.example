# ============================================================
#  SIS BEAUTY — Variáveis de ambiente
#  Copie este arquivo para ".env.local" e preencha os valores.
#  NUNCA suba o .env.local para o Git (já está no .gitignore).
# ============================================================

# URL pública do site (em produção: https://seudominio.com.br)
APP_URL=http://localhost:3000

# ---------------- MELHOR ENVIO ----------------
# Token de API (Bearer). Sandbox p/ testes, produção p/ valer.
MELHOR_ENVIO_TOKEN=
# Use sandbox enquanto testa:
# https://sandbox.melhorenvio.com.br  (testes)
# https://www.melhorenvio.com.br      (produção)
MELHOR_ENVIO_URL=https://www.melhorenvio.com.br
MELHOR_ENVIO_UA=SIS Beauty (seu-email@dominio.com)

# CEP de onde os produtos são enviados (só números)
CEP_ORIGEM=

# Serviço de envio padrão p/ a etiqueta (1 = PAC, 2 = SEDEX)
MELHOR_ENVIO_SERVICO=1

# Dados do remetente (para gerar a etiqueta)
LOJA_NOME=SIS Beauty
LOJA_TELEFONE=
LOJA_EMAIL=contato@sisbeauty.com.br
LOJA_DOCUMENTO=
LOJA_ENDERECO=
LOJA_NUMERO=
LOJA_BAIRRO=
LOJA_CIDADE=
LOJA_UF=

# ---------------- MERCADO PAGO ----------------
# Access Token (Produção ou Teste) do painel de Desenvolvedores
MP_ACCESS_TOKEN=
# Public Key (caso use checkout transparente no futuro)
NEXT_PUBLIC_MP_PUBLIC_KEY=

# ---------------- CONTATO (front) ----------------
NEXT_PUBLIC_WHATSAPP=5599999999999
NEXT_PUBLIC_INSTAGRAM=https://instagram.com/sisbeauty
