# ============================================================
#  SIS BEAUTY — Variáveis de ambiente
#  Copie este arquivo para ".env.local" e preencha os valores.
#  NUNCA suba o .env.local para o Git (já está no .gitignore).
# ============================================================

# URL pública do site (em produção: https://seudominio.com.br)
APP_URL=http://localhost:3000

# ---------------- MELHOR ENVIO ----------------
# Token de API (Bearer). Sandbox p/ testes, produção p/ valer.
MELHOR_ENVIO_TOKEN=
# Use sandbox enquanto testa:
# https://sandbox.melhorenvio.com.br  (testes)
# https://www.melhorenvio.com.br      (produção)
MELHOR_ENVIO_URL=https://www.melhorenvio.com.br
MELHOR_ENVIO_UA=SIS Beauty (seu-email@dominio.com)

# CEP de onde os produtos são enviados (só números)
CEP_ORIGEM=

# Serviço de envio padrão p/ a etiqueta (1 = PAC, 2 = SEDEX)
# Se este serviço não atender o CEP, o sistema escolhe outro automaticamente.
MELHOR_ENVIO_SERVICO=1

# ---------------- DIMENSÕES DA EMBALAGEM ----------------
# Controla peso e tamanho da caixa no cálculo de frete e na etiqueta.
# Se deixar em branco, usa os padrões definidos no código.
# Peso de 1 pote cheio (kg) e peso extra da caixa/plástico (kg)
PACOTE_PESO_UNITARIO=0.18
PACOTE_PESO_EMBALAGEM=0.05
# Caixa para até 1 pote (cm) — altura x largura x comprimento
PACOTE_1_ALTURA=12
PACOTE_1_LARGURA=9
PACOTE_1_COMPRIMENTO=8
# Caixa para até 2 potes (cm)
PACOTE_2_ALTURA=12
PACOTE_2_LARGURA=13
PACOTE_2_COMPRIMENTO=9
# Caixa para 3 ou mais potes (cm)
PACOTE_3_ALTURA=14
PACOTE_3_LARGURA=16
PACOTE_3_COMPRIMENTO=12

# Dados do remetente (para gerar a etiqueta)
LOJA_NOME=SIS Beauty
LOJA_TELEFONE=
LOJA_EMAIL=contato@sisbeauty.com.br
LOJA_DOCUMENTO=
LOJA_ENDERECO=
LOJA_NUMERO=
LOJA_BAIRRO=
LOJA_CIDADE=
LOJA_UF=

# ---------------- MERCADO PAGO ----------------
# Access Token (Produção ou Teste) do painel de Desenvolvedores
MP_ACCESS_TOKEN=
# Public Key (caso use checkout transparente no futuro)
NEXT_PUBLIC_MP_PUBLIC_KEY=
# Secret do webhook (painel MP > Webhooks). Se preenchido, valida a assinatura.
MP_WEBHOOK_SECRET=

# ---------------- RASTREAMENTO (analytics) ----------------
# Meta (Facebook/Instagram) Pixel — só o ID numérico
NEXT_PUBLIC_FB_PIXEL_ID=
# Google Analytics 4 (formato G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# ---------------- E-MAIL (Resend) ----------------
# Chave da API Resend (https://resend.com). Sem ela, e-mails são ignorados.
RESEND_API_KEY=
# Remetente verificado no Resend
EMAIL_FROM=SIS Beauty <pedidos@sisbeauty.com.br>

# ---------------- CONTATO (front) ----------------
NEXT_PUBLIC_WHATSAPP=5599999999999
NEXT_PUBLIC_INSTAGRAM=https://instagram.com/sisbeauty
